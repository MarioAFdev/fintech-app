# Entorno
APP_ENV=development
APP_NAME=FintechBancaria
APP_URL=http://localhost

# Base de datos
DB_HOST=database
DB_PORT=3306
DB_NAME=fintech_db
DB_USER=root
DB_PASS=root123

# JWT (cambia esta clave por una más segura en producción)
JWT_SECRET_KEY=tu_clave_super_secreta_para_jwt_minimo_32_caracteres
